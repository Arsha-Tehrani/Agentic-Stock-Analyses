# Slack Ingestion Gateway — Environment Variables
# Copy this file, fill in your real tokens, then run:
#   launchctl load ~/Library/LaunchAgents/com.agentic-workflow.slack-gateway.plist

# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN="your-slack-bot-token"

# Slack App Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN="your-slack-app-token"

# Gemini API Key
GEMINI_API_KEY="your-gemini-api-key"

# Optional: restrict input to a specific Slack channel (leave blank for all DMs)
SLACK_CHANNEL_ID=""

# Slack Output Reporter — Channel ID where daily pipeline results are posted
# Find it by right-clicking a channel in Slack → "Copy link" → extract the last part (e.g. C01234ABCDEF)
SLACK_OUTPUT_CHANNEL_ID=""
