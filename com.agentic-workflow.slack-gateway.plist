<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic-workflow.slack-gateway</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/arshatehrani/Documents/Agentic_Workflow/.venv/bin/python</string>
        <string>-m</string>
        <string>src.utils.slack_gateway</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/arshatehrani/Documents/Agentic_Workflow</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>SLACK_BOT_TOKEN</key>
        <string>__FILL_IN_YOUR_SLACK_BOT_TOKEN__</string>
        <key>SLACK_APP_TOKEN</key>
        <string>__FILL_IN_YOUR_SLACK_APP_TOKEN__</string>
        <key>GEMINI_API_KEY</key>
        <string>__FILL_IN_YOUR_GEMINI_API_KEY__</string>
