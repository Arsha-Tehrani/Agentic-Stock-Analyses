        <string>__FILL_IN_YOUR_OUTPUT_CHANNEL_ID__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/arshatehrani/Library/Logs/slack-gateway/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/arshatehrani/Library/Logs/slack-gateway/stderr.log</string>
</dict>
</plist>