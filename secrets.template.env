# Secrets Template — copy this file to secrets.env and fill in your real keys
#   cp secrets.template.env secrets.env
# secrets.env is gitignored and never committed.

# Gemini API Key (required for LLM agents)
GEMINI_API_KEY=your-gemini-api-key

# Finnhub API Key (required for wire news ingestion & portfolio enrichment)
FINNHUB_API_KEY=your-finnhub-api-key

# Slack Bot Token for Ingestion Gateway (starts with xoxb-)
SLACK_BOT_TOKEN=your-slack-bot-token

# Slack App Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=your-slack-app-token

# Optional: Slack Channel ID for restricting input (leave blank for all DMs)
SLACK_CHANNEL_ID=

# Slack Output Reporter — Channel ID where daily pipeline results are posted
SLACK_OUTPUT_CHANNEL_ID=